{
    "name": "indi-engine/newapp",
    "description": "Entry point for a blank Indi Engine AI project development from scratch",
    "type": "project",
    "repositories": [
      {"type": "git", "url": "https://github.com/indi-engine/system.git"},
      {"type": "git", "url": "https://github.com/indi-engine/client.git"},
      {"type": "git", "url": "https://github.com/indi-engine/ckeditor.git"},
      {"type": "git", "url": "https://github.com/indi-engine/ckfinder.git"},
      {
        "type": "package",
        "package": {
          "name": "indi-engine/bridge",
          "version": "v0.0.0",
          "dist": {
            "type": "zip",
            "url": "https://github.com/indi-engine/bridge/releases/latest/download/bridge.zip"
          }
        }
      },
      {"type": "composer", "url": "https://asset-packagist.org"}
    ],
    "require": {
        "indi-engine/system": "dev-master",
        "indi-engine/client": "dev-master",
        "indi-engine/ckeditor": "dev-master",
        "indi-engine/ckfinder": "dev-master"
    },
    "scripts": {    
        "post-update-cmd" : "@hook",
        "post-install-cmd": "@hook",
        "hook": "php vendor/indi-engine/system/hook/init"
    },
    "autoload": {
      "classmap": [
        "vendor/indi-engine/system/application/controllers/",
        "vendor/indi-engine/system/application/models/",
        "vendor/indi-engine/system/library/"
      ],
      "files": [
        "vendor/indi-engine/system/library/func.php",
        "vendor/indi-engine/system/library/Indi.php",
        "vendor/indi-engine/system/library/Indi/Ai.php",
        "vendor/indi-engine/system/library/Indi/Ai/Abstract.php",
        "vendor/indi-engine/system/library/Indi/Ai/Claude.php",
        "vendor/indi-engine/system/library/Indi/Ai/Gemini.php",
        "vendor/indi-engine/system/library/Indi/Ai/Grok.php",
        "vendor/indi-engine/system/library/Indi/Ai/OpenAI.php"
      ]
    }
}
